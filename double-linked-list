#include <stdio.h>
#include <stdlib.h>
#define MaxSize 100
#define OK 1
#define ERROR 0	
#define TRUE 1		
#define FALSE 0
#define OVERFLOW -2
typedef int Status;
typedef int ElemType;
typedef struct DuLnode {
	ElemType data;
	struct DuLnode* next;
	struct DULnode* prior;
}DuLnode, * DuLinkList;
void ListInsert_DuL(DuLinkList* L, int i, ElemType e) {
    DuLnode* p = *L;
    int j = 0;

    while (p != NULL && j < i - 1) {
        p = p->next;
        j++;
    }
    if (p == NULL) {
        return;
    }
    DuLnode* s = (DuLnode*)malloc(sizeof(DuLnode));
    s->data = e;
    s->next = p->next;
    if (p->next != NULL) {
        p->next->prior = s;
    }
    p->next = s;
    s->prior = p;
}
